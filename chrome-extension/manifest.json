{
  "manifest_version": 3,
  "name": "Veritas — Fitness Bro Fact Checker",
  "version": "0.2.5",
  "description": "Live fact-check warnings for fitness claims on YouTube, Twitter/X, and TikTok. Highlight any health claim and verify it instantly.",
  "permissions": [
    "storage",
    "contextMenus",
    "activeTab",
    "tabCapture",
    "sidePanel"
  ],
  "host_permissions": [
    "http://localhost/*",
    "https://veritas-api-ka3y.onrender.com/*",
    "https://veritas-api.onrender.com/*",
    "https://veritas-ruby.vercel.app/*",
    "https://*.youtube.com/*",
    "https://*.twitter.com/*",
    "https://*.x.com/*",
    "https://*.tiktok.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Veritas — Fact Checker",
    "default_icon": {
      "16": "icons/newIcon.png",
      "48": "icons/newIcon.png",
      "128": "icons/newIcon.png"
    }
  },
  "icons": {
    "16": "icons/newIcon.png",
    "48": "icons/newIcon.png",
    "128": "icons/newIcon.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content_script.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://*.youtube.com/*",
        "https://*.twitter.com/*",
        "https://*.x.com/*",
        "https://*.tiktok.com/*"
      ],
      "js": ["live_scanner.js"],
      "css": ["live_overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "web_accessible_resources": [
    {
      "resources": ["sounds/ring.mp3", "sounds/poke.mp3"],
      "matches": [
        "https://*.youtube.com/*",
        "https://*.twitter.com/*",
        "https://*.x.com/*",
        "https://*.tiktok.com/*"
      ]
    }
  ]
}
