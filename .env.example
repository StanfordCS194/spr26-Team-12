# Veritas credit-based MVP configuration
# Copy this file to .env or export vars in your shell before starting backend.

# Keep true for cached/demo behavior. Set false when keys are configured.
DEMO_MODE=true

# Model providers
PRIMARY_LLM_PROVIDER=openai
SECONDARY_LLM_PROVIDER=groq
SEARCH_PROVIDER=tavily

# OpenAI: structured extraction / final judge / reliable JSON
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4o-mini

# Groq: fast transcription + second verifier
GROQ_API_KEY=
GROQ_TEXT_MODEL=llama-3.3-70b-versatile
GROQ_TRANSCRIPTION_MODEL=whisper-large-v3-turbo

# Search provider, to be wired in Feature 1 two-agent source search
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=

# Upload limits
MAX_AUDIO_MB=25
TRANSCRIPTION_TIMEOUT_SECONDS=120
