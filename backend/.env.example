# ── Supabase (optional — falls back to local SQLite) ─────────────────────────
# Create project at https://supabase.com, then run setup_supabase.sql once.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_KEY=your_service_role_key_here

# ── Resemble AI Detect (optional — significantly improves detection accuracy) ─
# Get a free API key at: https://app.resemble.ai/account/api
# Resemble requires a publicly accessible HTTPS URL for audio files.
# Set BACKEND_URL to your deployed server (Resemble is skipped for http://).
RESEMBLE_API_KEY=
BACKEND_URL=http://localhost:8000
